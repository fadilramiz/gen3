  <joint name="joint_6" type="revolute">
    <origin xyz="0 0.00017505 -0.10593" rpy="1.5708 9.2076E-28 -8.2157E-15" />
    <parent link="spherical_wrist_1_link" />
    <child link="spherical_wrist_2_link" />
    <axis xyz="0 0 1" />
    <limit lower="-2.09" upper="2.09" effort="9" velocity="1.2218" />
  </joint>
  <link name="bracelet_link">
    <inertial>
      <origin xyz="-0.000281 -0.011402 -0.029798" rpy="0 0 0" />
      <mass value="0.5006" />
      <inertia ixx="0.000587" ixy="3E-06" ixz="3E-06" iyy="0.000369" iyz="0.000118" izz="0.000609" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_path}/bracelet_with_vision_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_path}/bracelet_with_vision_link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="joint_7" type="continuous">
    <origin xyz="0 -0.10593 -0.00017505" rpy="-1.5708 -5.5511E-17 9.6396E-17" />
    <parent link="spherical_wrist_2_link" />
    <child link="bracelet_link" />
    <axis xyz="0 0 1" />
    <limit effort="9" velocity="1.2218" />
  </joint>
  <link name="end_effector_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0" />
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0" />
    </inertial>
  </link>
  <joint name="end_effector" type="fixed">
    <origin xyz="0 0 -0.0615250000000001" rpy="3.14159265358979 1.09937075168372E-32 0" />
    <parent link="bracelet_link" />
    <child link="end_effector_link" />
    <axis xyz="0 0 0" />
  </joint>  
  <link name="camera_link" />
  <joint name="camera_module" type="fixed">
    <origin xyz="0 0.05639 -0.00305" rpy="-1.5708 -1.5708 0" />
    <parent link="end_effector_link" />
    <child  link="camera_link" />
  </joint>
  <link name="camera_depth_frame" />
  <joint name="depth_module" type="fixed">
    <origin xyz="0.0275 0.066 -0.00305" rpy="3.14159265358979 3.14159265358979 0" />
    <parent link="end_effector_link" />
    <child  link="camera_depth_frame" />
  </joint>
  <link name="camera_color_frame" />
  <joint name="color_module" type="fixed">
    <origin xyz="0 0.05639 -0.00305" rpy="3.14159265358979 3.14159265358979 0" />
    <parent link="end_effector_link" />
    <child  link="camera_color_frame" />
  </joint>

  <!-- ============================================================ -->
  <!-- Pince Panda + World link                                     -->
  <!-- ============================================================ -->

  <link name="world"/>
  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="panda_hand_joint" type="fixed">
    <parent link="end_effector_link"/>
    <child link="panda_hand"/>
    <origin rpy="0 0 1.5708" xyz="0 0 0"/>
  </joint>
  <link name="panda_hand">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/visual/hand.dae"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="${mesh_path}/hand.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="-0.01 0 0.03"/>
      <mass value="0.73"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.0025" iyz="0" izz="0.0017"/>
    </inertial>
  </link>
  <link name="panda_leftfinger">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/visual/finger.dae"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="${mesh_path}/finger.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.015"/>
      <inertia ixx="2.375E-6" ixy="0" ixz="0" iyy="2.375E-6" iyz="0" izz="7.5E-7"/>
    </inertial>
  </link>
  <link name="panda_rightfinger">
    <visual>
      <origin rpy="0 0 3.14159265359" xyz="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_path}/visual/finger.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 3.14159265359" xyz="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_path}/finger.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="2.375E-6" ixy="0" ixz="0" iyy="2.375E-6" iyz="0" izz="7.5E-7"/>
    </inertial>
  </link>
  <joint name="panda_finger_joint1" type="prismatic">
    <parent link="panda_hand"/>
    <child link="panda_leftfinger"/>
    <origin rpy="0 0 0" xyz="0 0 0.0584"/>
    <axis xyz="0 1 0"/>
    <limit effort="20" lower="0.0" upper="0.04" velocity="0.2"/>
    <dynamics damping="0.3"/>
  </joint>
  <joint name="panda_finger_joint2" type="prismatic">
    <parent link="panda_hand"/>
    <child link="panda_rightfinger"/>
    <origin rpy="0 0 0" xyz="0 0 0.0584"/>
    <axis xyz="0 -1 0"/>
    <limit effort="20" lower="0.0" upper="0.04" velocity="0.2"/>
    <mimic joint="panda_finger_joint1"/>
    <dynamics damping="0.3"/>
  </joint>

  <!-- ============================================================ -->
  <!-- Plugin Gazebo - Caméra RealSense (eye-in-hand)              -->
  <!-- ============================================================ -->
  <gazebo reference="camera_link">
    <!-- Caméra RGB -->
    <sensor name="camera_color" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>camera/color/image_raw</topic> <!-- Topic Gazebo direct -->
      <camera>
        <horizontal_fov>1.2112</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
    </sensor>

    <!-- Caméra de profondeur -->
    <sensor name="camera_depth" type="depth_camera">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <topic>camera/depth/image_raw</topic> <!-- Topic Gazebo direct -->
      <camera>
        <horizontal_fov>1.2112</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R_FLOAT32</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <!-- Plugin sensors system - requis pour activer les capteurs dans Gazebo Harmonic -->
  <gazebo>
    <plugin filename="libgz-sim-sensors-system.so"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>

</robot>